{
  "serverBaseUrl": "https://rodion.pro",
  "deviceId": "pc-main",
  "deviceKey": "MySecureActivityKey123!",
  "pollIntervalSec": 10,
  "privacy": {
    "blacklistApps": [
      "keepass.exe",
      "1password.exe"
    ],
    "blacklistTitlePatterns": [],
    "sendWindowTitle": true
  },
  "categories": [
    {
      "match": "(?:code|cursor|qoder|devenv|vs(?:code)?|rider(?:64)?|idea64|intellijidea64|webstorm(?:64)?|phpstorm(?:64)?|pycharm(?:64)?|goland(?:64)?|clion(?:64)?|datagrip(?:64)?|rubymine(?:64)?|fleet(?:64)?|studio64|eclipse|netbeans|codeblocks|androidstudio)\\.exe$",
      "category": "coding"
    },
    {
      "match": "(?:sublime_text|notepad\\+\\+|atom|brackets|vim|gvim|emacs|neovide|kate|gedit)\\.exe$",
      "category": "coding"
    },
    {
      "match": "(?:windowsterminal|wt|cmd|powershell|pwsh|conhost|bash|wsl|putty|mobaxterm|xshell|securecrt|cmder|tabby|wezterm|alacritty|hyper)\\.exe$",
      "category": "coding"
    },
    {
      "match": "(?:gitkraken|githubdesktop|sourcetree|smartgit|fork|tortoisegitproc|tortoisegitmerge|tortoisegitblame|tortoisesvnproc|beyondcompare|winmergeu|meld|kdiff3)\\.exe$",
      "category": "coding"
    },
    {
      "match": "(?:dbeaver|pgadmin4|mysqlworkbench|heidisql|sqlitebrowser|navicat|tableplus|mongodbcompass.*|studio3t|redisinsight|postman|insomnia|soapui|fiddler|charles|proxifier)\\.exe$",
      "category": "coding"
    },
    {
      "match": "(?:docker desktop|dockerd|rancher desktop|podman desktop|lens|k9s|terraform|packer)\\.exe$",
      "category": "devops"
    },

    {
      "match": "(?:chrome|firefox|msedge|brave|opera|opera_gx|vivaldi|yandex|chromium|waterfox|tor|arc)\\.exe$",
      "category": "browser"
    },

    {
      "match": "(?:telegram|discord|slack|mattermost|element|signal|whatsapp|viber|skype|icq|wechat|line)\\.exe$",
      "category": "comms"
    },

    {
      "match": "(?:teams|zoom|webex|gotomeeting|gotowebinar|teamviewer|anydesk|chrome_remote_desktop_host|mstsc)\\.exe$",
      "category": "meetings"
    },

    {
      "match": "(?:notion|obsidian|logseq|joplin|evernote|standardnotes|simplenote|anki|todoist|ticktick|trello|clickup|asana)\\.exe$",
      "category": "productivity"
    },

    {
      "match": "(?:winword|excel|powerpnt|outlook|onenote|visio|mspub)\\.exe$",
      "category": "office"
    },
    {
      "match": "(?:acrord32|acrord64|acrobat|foxitpdfreader|sumatrapdf|pdfxedit|okular|soffice|soffice\\.bin|swriter|scalc|simpress|sdraw)\\.exe$",
      "category": "office"
    },

    {
      "match": "(?:photoshop|illustrator|afterfx|premierepro|audition|lightroom|xd|bridge)\\.exe$",
      "category": "design"
    },
    {
      "match": "(?:figma|krita|gimp-?2\\.10|inkscape|paintdotnet|clipstudiopaint|affinityphoto|affinitydesigner|affinitypublisher)\\.exe$",
