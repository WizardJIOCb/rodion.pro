import type { APIRoute } from 'astro';
import { eq, sql } from 'drizzle-orm';
import { hashApiKey, floorToMinute, broadcastSSE } from '@/lib/activity';
import { hasActivityDb, requireActivityDb } from '@/lib/activity-db';

type MinuteSlice = { tsMinute: Date; weightMs: number };

function splitIntoMinuteSlices(start: Date, end: Date, floorToMinuteFn: (d: Date) => Date): MinuteSlice[] {
  const slices: MinuteSlice[] = [];
  let cursor = start.getTime();
  const endMs = end.getTime();

  while (cursor < endMs) {
    const cursorDate = new Date(cursor);
    const minuteStart = floorToMinuteFn(cursorDate).getTime();
    const minuteEnd = minuteStart + 60_000;

    const sliceEnd = Math.min(endMs, minuteEnd);
    const weightMs = sliceEnd - cursor;

    if (weightMs > 0) {
      slices.push({ tsMinute: new Date(minuteStart), weightMs });
    }
    cursor = sliceEnd;
  }

  return slices;
}

function distributeInt(total: number, weights: number[]): number[] {
  const n = weights.length;
  if (n === 0) return [];
  if (total <= 0) return new Array(n).fill(0);

  const sum = weights.reduce((a, b) => a + b, 0);
  if (sum <= 0) return new Array(n).fill(0);

  const result: number[] = new Array(n).fill(0);
  let distributed = 0;

  // Distribute proportionally
  for (let i = 0; i < n; i++) {
    const portion = Math.floor((weights[i] / sum) * total);
    result[i] = portion;
    distributed += portion;
  }

  // Distribute remainder
  let remainder = total - distributed;
  for (let i = 0; i < n && remainder > 0; i++) {
    result[i]++;
    remainder--;
  }

  return result;
}

function clampInt(n: any, min: number, max: number) {
  const x = Number.isFinite(n) ? Math.round(n) : 0;
  return Math.max(min, Math.min(max, x));
}

export const POST: APIRoute = async ({ request }) => {
  if (!(await hasActivityDb())) {
    return new Response(JSON.stringify({ error: 'DB not configured' }), {
      status: 503,
      headers: { 'Content-Type': 'application/json' },
    });
  }

  const deviceId = request.headers.get('x-device-id');
  const deviceKey = request.headers.get('x-device-key');

  if (!deviceId || !deviceKey) {
    return new Response(JSON.stringify({ error: 'Missing device credentials' }), {
      status: 401,
      headers: { 'Content-Type': 'application/json' },
    });
  }

  const db = await requireActivityDb();
  const schema = await import('@/db/schema');
  
  // Verify device
  const device = await db.query[schema.activityDevices].findFirst({
    where: eq(schema.activityDevices.id, deviceId),
  });

  if (!device || device.apiKeyHash !== hashApiKey(deviceKey)) {
    return new Response(JSON.stringify({ error: 'Invalid device credentials' }), {
      status: 401,
      headers: { 'Content-Type': 'application/json' },
    });
  }

  try {
    const body = await request.json();
    const { sentAt, intervalSec, now, counts } = body;

    if (!now || !sentAt) {
      return new Response(JSON.stringify({ error: 'Missing required fields' }), {
        status: 400,
        headers: { 'Content-Type': 'application/json' },
      });
    }

    const timestamp = new Date(sentAt);

    // достанем предыдущее now заранее (нужно и для split, и для day reset)
    const existingNow = await db.query.activityNow.findFirst({
      where: eq(activityNow.deviceId, deviceId),
    });

    const app = now.app || '';
    const windowTitle = now.windowTitle || '';
    const category = now.category || 'unknown';
    const isAfk = !!now.isAfk;

    // interval / durations
    const interval = intervalSec || 10;

    // если агент прислал durations — используем их
    const dtSec = clampInt(body?.durations?.dtSec ?? interval, 1, 60);
    let activeSec = clampInt(body?.durations?.activeSec ?? (isAfk ? 0 : dtSec), 0, dtSec);
    let afkSec = clampInt(body?.durations?.afkSec ?? (isAfk ? dtSec : 0), 0, dtSec);

    // нормализуем на всякий случай
    const total = activeSec + afkSec;
    if (total !== dtSec) {
      if (total > 0) {
        // приводим к dtSec пропорцией
        activeSec = Math.round((activeSec * dtSec) / total);
        activeSec = Math.max(0, Math.min(dtSec, activeSec));
        afkSec = dtSec - activeSec;
      } else {
        activeSec = isAfk ? 0 : dtSec;
        afkSec = dtSec - activeSec;
      }
    }

    const keys = counts?.keys || 0;
    const clicks = counts?.clicks || 0;
    const scroll = counts?.scroll || 0;

    // --- определяем границы интервала ---
    const end = timestamp;

    // по умолчанию: end - dtSec
    let start = new Date(end.getTime() - dtSec * 1000);

    // если есть previous updatedAt и оно "рядом" (не час назад!), используем его
    if (existingNow?.updatedAt) {
      const prev = new Date(existingNow.updatedAt);
      const gapSec = (end.getTime() - prev.getTime()) / 1000;
      // доверяем prev, только если он в пределах 3 тиков (иначе агент был выключен)
      if (gapSec > 0 && gapSec <= dtSec * 3) {
        start = prev;
      }
    }

    // режем по минутам
    const slices = splitIntoMinuteSlices(start, end, floorToMinute);
    const weights = slices.map(s => s.weightMs);

    const activeParts = distributeInt(activeSec, weights);
    const afkParts = distributeInt(afkSec, weights);
    const keysParts = distributeInt(keys, weights);
    const clicksParts = distributeInt(clicks, weights);
    const scrollParts = distributeInt(scroll, weights);

    // upsert каждой минуты
    for (let i = 0; i < slices.length; i++) {
      const s = slices[i];
      const a = activeParts[i] || 0;
      const f = afkParts[i] || 0;
      const k = keysParts[i] || 0;
      const c = clicksParts[i] || 0;
      const sc = scrollParts[i] || 0;

      // можно пропускать полностью нулевые записи
      if (a === 0 && f === 0 && k === 0 && c === 0 && sc === 0) continue;

      await db.insert(activityMinuteAgg).values({
        deviceId,
        tsMinute: s.tsMinute,
        app,
        windowTitle,
        category,
        activeSec: a,
        afkSec: f,
        keys: k,
        clicks: c,
        scroll: sc,
      }).onConflictDoUpdate({
        target: [
          activityMinuteAgg.deviceId,
          activityMinuteAgg.tsMinute,
          activityMinuteAgg.app,
          activityMinuteAgg.windowTitle,
          activityMinuteAgg.category,
        ],
        set: {
          activeSec: sql`${activityMinuteAgg.activeSec} + excluded.active_sec`,
          afkSec: sql`${activityMinuteAgg.afkSec} + excluded.afk_sec`,
          keys: sql`${activityMinuteAgg.keys} + excluded.keys`,
          clicks: sql`${activityMinuteAgg.clicks} + excluded.clicks`,
          scroll: sql`${activityMinuteAgg.scroll} + excluded.scroll`,
        },
      });
    }

    const todayStart = new Date(timestamp);
    todayStart.setHours(0, 0, 0, 0);

    const existingDay = existingNow?.updatedAt
      ? new Date(existingNow.updatedAt).setHours(0, 0, 0, 0)
      : null;

    const sameDay = existingDay !== null && existingDay === todayStart.getTime();

    if (!existingNow) {
      await db.insert(activityNow).values({
        deviceId,
        updatedAt: timestamp,
        app: now.app || null,
        windowTitle: now.windowTitle || null,
        category,
        isAfk,
        countsTodayKeys: keys,
        countsTodayClicks: clicks,
        countsTodayScroll: scroll,
        countsTodayActiveSec: activeSec,
      });
    } else if (sameDay) {
      await db.update(activityNow).set({
        updatedAt: timestamp,
        app: now.app || null,
        windowTitle: now.windowTitle || null,
        category,
        isAfk,
        countsTodayKeys: sql`${activityNow.countsTodayKeys} + ${keys}`,
        countsTodayClicks: sql`${activityNow.countsTodayClicks} + ${clicks}`,
        countsTodayScroll: sql`${activityNow.countsTodayScroll} + ${scroll}`,
        countsTodayActiveSec: sql`${activityNow.countsTodayActiveSec} + ${activeSec}`,
      }).where(eq(activityNow.deviceId, deviceId));
    } else {
      // New day — reset counters
      await db.update(activityNow).set({
        updatedAt: timestamp,
        app: now.app || null,
        windowTitle: now.windowTitle || null,
        category,
        isAfk,
        countsTodayKeys: keys,
        countsTodayClicks: clicks,
        countsTodayScroll: scroll,
        countsTodayActiveSec: activeSec,
      }).where(eq(activityNow.deviceId, deviceId));
    }

    // Update device last_seen_at
    await db.update(activityDevices)
      .set({ lastSeenAt: timestamp })
      .where(eq(activityDevices.id, deviceId));

    // Broadcast to SSE subscribers
    broadcastSSE(deviceId, {
      deviceId,
      updatedAt: timestamp.toISOString(),
      now: { app: now.app, windowTitle: now.windowTitle, category, isAfk },
      countsToday: {
        keys: sameDay ? (existingNow!.countsTodayKeys + keys) : keys,
        clicks: sameDay ? (existingNow!.countsTodayClicks + clicks) : clicks,
        scroll: sameDay ? (existingNow!.countsTodayScroll + scroll) : scroll,
        activeSec: sameDay ? (existingNow!.countsTodayActiveSec + activeSec) : activeSec,
      },
    });

    return new Response(JSON.stringify({ ok: true }), {
      status: 200,
      headers: { 'Content-Type': 'application/json' },
    });
  } catch (error) {
    console.error('[activity/ingest] Error:', error);
    return new Response(JSON.stringify({ error: 'Internal error' }), {
      status: 500,
      headers: { 'Content-Type': 'application/json' },
    });
  }
};
