---
import Layout from '@/layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t('misc.notFound')} description="Page not found" noindex>
  <div class="mx-auto max-w-3xl px-4 py-24 text-center">
    <div class="terminal-window inline-block mb-8">
      <div class="terminal-header">
        <span class="terminal-dot bg-danger"></span>
        <span class="terminal-dot bg-warn"></span>
        <span class="terminal-dot bg-success"></span>
      </div>
      <div class="terminal-body text-left">
        <div class="flex items-center gap-2">
          <span class="terminal-prompt">$</span>
          <span>cat page.html</span>
        </div>
        <div class="text-danger mt-1">Error: File not found (404)</div>
      </div>
    </div>
    
    <h1 class="text-4xl font-bold text-text mb-4">404</h1>
    <p class="text-muted mb-8">{t('misc.notFound')}</p>
    
    <a href={getLocalizedPath('/', lang)} class="btn btn-primary">
      {t('misc.backHome')}
    </a>
  </div>
</Layout>
