---
import Layout from '@/layouts/Layout.astro';
import ActivityDashboard from '@/components/ActivityDashboard.tsx';

const title = 'Activity Dashboard';
const description = 'Live activity monitoring dashboard';
---

<Layout title={title} description={description}>
  <div class="mx-auto max-w-6xl px-4 py-12">
    <h1 class="text-3xl font-bold text-text mb-8">Activity Dashboard</h1>
    <ActivityDashboard client:load />
  </div>
</Layout>