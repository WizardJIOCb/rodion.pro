---
import Layout from '@/layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getLangFromUrl } from '@/i18n';
import FreshHome from '@/components/FreshHome.astro';

const lang = getLangFromUrl(Astro.url);

Astro.cookies.set('lang', lang, {
  path: '/',
  maxAge: 60 * 60 * 24 * 365,
  httpOnly: false,
  sameSite: 'lax',
});

const title = 'Home';
const description = 'Rodion Kalimullin - Senior Full-Stack Developer, Tech Lead, and DevOps engineer';

const posts = await getCollection(`blog-${lang}`, ({ data }) => !data.draft);
const latestPosts = posts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<Layout title={title} description={description}>
  <FreshHome lang={lang} latestPosts={latestPosts} />
</Layout>
