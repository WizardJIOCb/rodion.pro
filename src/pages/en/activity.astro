---
import Layout from '@/layouts/Layout.astro';
import ActivityDashboard from '@/components/ActivityDashboard.tsx';

const title = 'Activity Dashboard';
const description = 'Real-time activity monitoring dashboard';
const lang = 'en';
---

<Layout title={title} description={description}>
  <div class="mx-auto max-w-6xl px-4 py-12">
    <h1 class="text-3xl font-bold text-text mb-8">Activity Dashboard</h1>
    <ActivityDashboard lang={lang} client:load />
  </div>
</Layout>