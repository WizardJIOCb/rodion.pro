---
import Layout from '@/layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '@/i18n';
import { nowSections, getLastUpdated } from '@/data/now';
import ResumeNowBlock from '@/components/ResumeNowBlock.astro';
import { resumeShortEn } from '@/data/resumeShort';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const sections = nowSections;
const lastUpdated = getLastUpdated();
---

<Layout title={t('nav.now')} description="What I am doing now">
  <div class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="text-3xl font-bold text-text mb-8">{t('nav.now')}</h1>
    
    <ResumeNowBlock data={resumeShortEn} lang={lang} />
    
    <div class="prose prose-invert">
      <p class="text-muted">
        This page is inspired by the /now movement. Here I share what I am currently focused on.
      </p>
      
      <div class="mt-8 space-y-6">
        {sections.map(section => (
          <section class="card">
            <h2 class="text-xl font-semibold text-accent mb-2">
              {section.title[lang]}
            </h2>
            <p class="text-muted">
              {section.content[lang]}
            </p>
            {section.items && section.items.length > 0 && (
              <ul class="mt-3 space-y-2">
                {section.items.map(item => (
                  <li class="text-muted text-sm">
                    <strong>{item.title[lang]}</strong>
                    {item.description && (
                      <>
                        {' — '}
                        <span>{item.description[lang]}</span>
                      </>
                    )}
                  </li>
                ))}
              </ul>
            )}
          </section>
        ))}
      </div>
      
      <p class="mt-8 text-sm text-muted">
        {lang === 'ru' ? 'Последнее обновление' : 'Last updated'}: {lastUpdated[lang]}
      </p>
    </div>
  </div>
</Layout>
