---
import Layout from '@/layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '@/i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t('nav.now')} description="What I am doing now">
  <div class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="text-3xl font-bold text-text mb-8">{t('nav.now')}</h1>
    
    <div class="prose prose-invert">
      <p class="text-muted">
        This page is inspired by the /now movement. Here I share what I am currently focused on.
      </p>
      
      <div class="mt-8 space-y-6">
        <section class="card">
          <h2 class="text-xl font-semibold text-accent mb-2">Work</h2>
          <p class="text-muted">Content will be added.</p>
        </section>
        
        <section class="card">
          <h2 class="text-xl font-semibold text-accent mb-2">Projects</h2>
          <p class="text-muted">Content will be added.</p>
        </section>
        
        <section class="card">
          <h2 class="text-xl font-semibold text-accent mb-2">Learning</h2>
          <p class="text-muted">Content will be added.</p>
        </section>
      </div>
      
      <p class="mt-8 text-sm text-muted">Last updated: February 2026</p>
    </div>
  </div>
</Layout>
