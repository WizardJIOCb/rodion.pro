---
import Layout from '@/layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '@/i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t('nav.now')} description={lang === 'ru' ? 'Чем занимаюсь сейчас' : 'What I am doing now'}>
  <div class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="text-3xl font-bold text-text mb-8">{t('nav.now')}</h1>
    
    <div class="prose prose-invert">
      <p class="text-muted">
        {lang === 'ru' 
          ? 'Эта страница вдохновлена движением /now. Здесь я рассказываю, чем занимаюсь в данный момент.'
          : 'This page is inspired by the /now movement. Here I share what I am currently focused on.'}
      </p>
      
      <div class="mt-8 space-y-6">
        <section class="card">
          <h2 class="text-xl font-semibold text-accent mb-2">
            {lang === 'ru' ? 'Работа' : 'Work'}
          </h2>
          <p class="text-muted">
            {lang === 'ru' ? 'Контент будет добавлен.' : 'Content will be added.'}
          </p>
        </section>
        
        <section class="card">
          <h2 class="text-xl font-semibold text-accent mb-2">
            {lang === 'ru' ? 'Проекты' : 'Projects'}
          </h2>
          <p class="text-muted">
            {lang === 'ru' ? 'Контент будет добавлен.' : 'Content will be added.'}
          </p>
        </section>
        
        <section class="card">
          <h2 class="text-xl font-semibold text-accent mb-2">
            {lang === 'ru' ? 'Изучаю' : 'Learning'}
          </h2>
          <p class="text-muted">
            {lang === 'ru' ? 'Контент будет добавлен.' : 'Content will be added.'}
          </p>
        </section>
      </div>
      
      <p class="mt-8 text-sm text-muted">
        {lang === 'ru' 
          ? 'Последнее обновление: Февраль 2026'
          : 'Last updated: February 2026'}
      </p>
    </div>
  </div>
</Layout>
