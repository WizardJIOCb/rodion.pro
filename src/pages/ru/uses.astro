---
import Layout from '@/layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '@/i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const categories = lang === 'ru' 
  ? [
      {
        title: 'Разработка',
        items: [
          { name: 'VS Code / Cursor', desc: 'Основной редактор с AI-ассистентом' },
          { name: 'Warp', desc: 'Терминал с AI-функциями' },
          { name: 'Docker Desktop', desc: 'Контейнеризация' },
        ]
      },
      {
        title: 'Инструменты',
        items: [
          { name: 'Arc Browser', desc: 'Основной браузер' },
          { name: 'Raycast', desc: 'Лаунчер и автоматизация' },
          { name: 'Obsidian', desc: 'Заметки и PKM' },
        ]
      },
      {
        title: 'Железо',
        items: [
          { name: 'MacBook Pro M3', desc: 'Основная машина' },
          { name: 'Keychron K2', desc: 'Механическая клавиатура' },
        ]
      },
    ]
  : [
      {
        title: 'Development',
        items: [
          { name: 'VS Code / Cursor', desc: 'Main editor with AI assistant' },
          { name: 'Warp', desc: 'Terminal with AI features' },
          { name: 'Docker Desktop', desc: 'Containerization' },
        ]
      },
      {
        title: 'Tools',
        items: [
          { name: 'Arc Browser', desc: 'Main browser' },
          { name: 'Raycast', desc: 'Launcher and automation' },
          { name: 'Obsidian', desc: 'Notes and PKM' },
        ]
      },
      {
        title: 'Hardware',
        items: [
          { name: 'MacBook Pro M3', desc: 'Main machine' },
          { name: 'Keychron K2', desc: 'Mechanical keyboard' },
        ]
      },
    ];
---

<Layout title={t('nav.uses')} description={lang === 'ru' ? 'Мой стек инструментов' : 'My tools and setup'}>
  <div class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="text-3xl font-bold text-text mb-4">{t('nav.uses')}</h1>
    <p class="text-muted mb-8">
      {lang === 'ru' 
        ? 'Инструменты, железо и софт, которые я использую в работе.'
        : 'Tools, hardware and software I use for work.'}
    </p>
    
    <div class="space-y-8">
      {categories.map(category => (
        <section>
          <h2 class="text-xl font-semibold text-accent mb-4 flex items-center gap-2">
            <span class="text-muted font-mono text-sm">#</span>
            {category.title}
          </h2>
          <div class="space-y-3">
            {category.items.map(item => (
              <div class="card flex items-start gap-4">
                <div class="w-2 h-2 rounded-full bg-accent mt-2 shrink-0"></div>
                <div>
                  <div class="font-medium text-text">{item.name}</div>
                  <div class="text-sm text-muted">{item.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>
</Layout>
