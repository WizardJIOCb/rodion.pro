---
import Layout from '@/layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '@/i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t('nav.resume')} description={lang === 'ru' ? 'Моё резюме' : 'My resume'}>
  <div class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="text-3xl font-bold text-text mb-8">{t('nav.resume')}</h1>
    
    <div class="space-y-8">
      <!-- Summary -->
      <section>
        <h2 class="text-xl font-semibold text-accent mb-4 flex items-center gap-2">
          <span class="text-muted font-mono text-sm">#</span>
          {lang === 'ru' ? 'О себе' : 'Summary'}
        </h2>
        <div class="card">
          <p class="text-muted">
            {lang === 'ru' 
              ? 'Разработчик с опытом в системной архитектуре, DevOps и AI/ML инструментах.'
              : 'Developer with experience in system architecture, DevOps, and AI/ML tooling.'}
          </p>
        </div>
      </section>
      
      <!-- Experience -->
      <section>
        <h2 class="text-xl font-semibold text-accent mb-4 flex items-center gap-2">
          <span class="text-muted font-mono text-sm">#</span>
          {lang === 'ru' ? 'Опыт' : 'Experience'}
        </h2>
        <div class="space-y-4">
          <div class="card">
            <p class="text-muted text-sm">
              {lang === 'ru' ? 'Информация будет добавлена.' : 'Information will be added.'}
            </p>
          </div>
        </div>
      </section>
      
      <!-- Skills -->
      <section>
        <h2 class="text-xl font-semibold text-accent mb-4 flex items-center gap-2">
          <span class="text-muted font-mono text-sm">#</span>
          {lang === 'ru' ? 'Навыки' : 'Skills'}
        </h2>
        <div class="card">
          <div class="flex flex-wrap gap-2">
            {['TypeScript', 'Node.js', 'Python', 'Go', 'Docker', 'Kubernetes', 'PostgreSQL', 'Redis'].map(skill => (
              <span class="tag">{skill}</span>
            ))}
          </div>
        </div>
      </section>
    </div>
  </div>
</Layout>
