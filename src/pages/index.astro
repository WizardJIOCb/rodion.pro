---
import Layout from '@/layouts/Layout.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n';
import { getFeaturedProjects } from '@/data/projects';
import { resumeShortRu, resumeShortEn } from '@/data/resumeShort';
import TerminalHero from '@/components/TerminalHero.astro';
import ProjectCard from '@/components/ProjectCard.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const resume = lang === 'ru' ? resumeShortRu : resumeShortEn;
const fullResumeHref = 'https://rodion.pro/ru/resume';

Astro.cookies.set('lang', lang, {
  path: '/',
  maxAge: 60 * 60 * 24 * 365,
  httpOnly: false,
  sameSite: 'lax',
});

const title = lang === 'ru' ? 'Главная' : 'Home';
const description = lang === 'ru'
  ? 'Персональный сайт Rodion - разработчик, DevOps, AI энтузиаст'
  : 'Personal website of Rodion - developer, DevOps, AI enthusiast';

const featuredProjects = getFeaturedProjects(lang);
---

<Layout title={title} description={description}>
  <div class="mx-auto max-w-5xl px-4 py-12">
    <TerminalHero lang={lang} />

    <section class="mt-16">
      <div class="mb-8 flex items-center justify-between">
        <h2 class="text-2xl font-bold text-text">{t('section.featured')}</h2>
        <a href={getLocalizedPath('/projects', lang)} class="link text-sm">
          {t('section.viewAll')} &rarr;
        </a>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {featuredProjects.map((project) => (
          <ProjectCard {...project} lang={lang} />
        ))}
      </div>
    </section>

    <section class="mt-16">
      <div class="mb-8 flex flex-col justify-between gap-3 sm:flex-row sm:items-end">
        <div>
          <h2 class="text-2xl font-bold text-text">
            {lang === 'ru' ? 'Резюме' : 'Resume'}
          </h2>
          <p class="mt-2 text-sm text-muted">
            {lang === 'ru'
              ? 'Коротко о специализации, опыте и формате работы.'
              : 'A short overview of specialization, experience, and work format.'}
          </p>
        </div>
        <a href={fullResumeHref} class="btn btn-secondary">
          {lang === 'ru' ? 'Полное резюме' : 'Full resume'}
        </a>
      </div>

      <div class="rounded-lg border border-border bg-surface p-6 shadow-sm">
        <div class="grid gap-8 lg:grid-cols-[1.15fr_0.85fr]">
          <div>
            <p class="font-mono text-sm text-accent">{resume.title}</p>
            <h3 class="mt-2 text-2xl font-bold text-text">{resume.name}</h3>
            <p class="mt-4 max-w-2xl text-sm leading-6 text-muted">
              {resume.highlights[0]}
            </p>
            <div class="mt-5 flex flex-wrap gap-2">
              {resume.keySpecialization.slice(0, 6).map((item) => (
                <span class="tag">{item}</span>
              ))}
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-1">
            <div class="rounded-md border border-border bg-bg p-4">
              <div class="font-mono text-xs text-muted">
                {lang === 'ru' ? 'Опыт' : 'Experience'}
              </div>
              <div class="mt-1 text-2xl font-bold text-text">{resume.experience}</div>
            </div>
            <div class="rounded-md border border-border bg-bg p-4">
              <div class="font-mono text-xs text-muted">
                {lang === 'ru' ? 'Формат' : 'Format'}
              </div>
              <div class="mt-1 text-base font-semibold text-text">{resume.workFormat}</div>
            </div>
          </div>
        </div>

        <div class="mt-6 grid gap-4 md:grid-cols-2">
          {resume.experienceShort.slice(0, 4).map((item) => (
            <div class="rounded-md border border-border bg-bg p-4">
              <h4 class="font-semibold text-text">{item.company}</h4>
              <p class="mt-1 text-sm text-accent">{item.role}</p>
              <p class="mt-2 text-sm leading-6 text-muted">{item.bullets.join(', ')}</p>
            </div>
          ))}
        </div>

        <div class="mt-6 flex flex-wrap gap-2">
          {resume.stackChips.slice(0, 12).map((tech) => (
            <span class="rounded-md border border-border bg-bg px-3 py-2 text-sm font-medium text-text">
              {tech}
            </span>
          ))}
        </div>

        <div class="mt-6">
          <a href={fullResumeHref} class="link font-medium">
            {lang === 'ru' ? 'Открыть полное резюме' : 'Open full resume'} &rarr;
          </a>
        </div>
      </div>
    </section>
  </div>
</Layout>
