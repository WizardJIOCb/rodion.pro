---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();

const footerLinks = [
  { key: 'nav.projects' as const, path: '/projects' },
  { key: 'nav.blog' as const, path: '/blog' },
  { key: 'nav.resume' as const, path: '/resume' },
  { key: 'nav.contact' as const, path: '/contact' },
];

const socialLinks = [
  { name: 'GitHub', url: 'https://github.com/WizardJIOCb', icon: 'github' },
  { name: 'Telegram', url: 'https://t.me/WizardJIOCb', icon: 'telegram' },
];
---

<footer class="border-t border-border bg-surface2/50">
  <div class="mx-auto max-w-5xl px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <a href={getLocalizedPath('/', lang)} class="font-mono text-lg font-semibold text-accent">
          ~/rodion
        </a>
        <p class="mt-2 text-sm text-muted max-w-xs">
          {lang === 'ru' 
            ? 'Разработчик, DevOps, AI энтузиаст. Пишу код, строю системы, изучаю AI.' 
            : 'Developer, DevOps, AI enthusiast. Writing code, building systems, exploring AI.'}
        </p>
      </div>
      
      <!-- Links -->
      <div>
        <h3 class="font-semibold text-text mb-4">
          {lang === 'ru' ? 'Навигация' : 'Navigation'}
        </h3>
        <ul class="space-y-2">
          {footerLinks.map(({ key, path }) => (
            <li>
              <a 
                href={getLocalizedPath(path, lang)} 
                class="text-sm text-muted hover:text-accent transition-colors"
              >
                {t(key)}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      <!-- Social -->
      <div>
        <h3 class="font-semibold text-text mb-4">
          {lang === 'ru' ? 'Связь' : 'Connect'}
        </h3>
        <div class="flex gap-3">
          {socialLinks.map(({ name, url, icon }) => (
            <a
              href={url}
              target="_blank"
              rel="noopener noreferrer"
              class="p-2 rounded-md border border-border text-muted hover:text-accent hover:border-accent/50 transition-colors"
              aria-label={name}
            >
              {icon === 'github' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
              )}
              {icon === 'telegram' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>
    </div>
    
    <div class="mt-8 pt-8 border-t border-border flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-sm text-muted">
        &copy; {year} Rodion. {t('footer.rights')}.
      </p>
      <p class="text-sm text-muted">
        {t('footer.builtWith')} <span class="text-accent">Astro</span> & <span class="text-accent">Tailwind</span>
      </p>
    </div>
  </div>
</footer>
