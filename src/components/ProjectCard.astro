---
import type { Lang } from '@/i18n';
import type { ProjectStatus } from '@/data/projects';

interface Props {
  id: string;
  title: string;
  tagline: string;
  status: ProjectStatus;
  links: {
    site?: string;
    github?: string;
    demo?: string;
  };
  stack: string[];
  highlights: string[];
  lang: Lang;
}

const { id, title, tagline, status, links, stack, highlights, lang } = Astro.props;

const statusLabels = {
  active: { ru: 'Активный', en: 'Active' },
  paused: { ru: 'На паузе', en: 'Paused' },
  archived: { ru: 'В архиве', en: 'Archived' },
};

const statusColors = {
  active: 'bg-success/20 text-success border-success/30',
  paused: 'bg-warn/20 text-warn border-warn/30',
  archived: 'bg-muted/20 text-muted border-muted/30',
};
---

<div class="card group" data-hover-glow>
  <div class="flex items-start justify-between gap-4 mb-3">
    <h3 class="text-lg font-semibold text-text group-hover:text-accent transition-colors">
      {title}
    </h3>
    <span class:list={[
      'px-2 py-0.5 text-xs rounded border shrink-0',
      statusColors[status]
    ]}>
      {statusLabels[status][lang]}
    </span>
  </div>
  
  <p class="text-muted text-sm mb-4">{tagline}</p>
  
  <!-- Stack -->
  <div class="flex flex-wrap gap-1.5 mb-4">
    {stack.map(tech => (
      <span class="tag text-xs">{tech}</span>
    ))}
  </div>
  
  <!-- Highlights -->
  <ul class="space-y-1 mb-4">
    {highlights.map(item => (
      <li class="flex items-start gap-2 text-sm text-muted">
        <span class="text-accent mt-1">•</span>
        <span>{item}</span>
      </li>
    ))}
  </ul>
  
  <!-- Links -->
  <div class="flex items-center gap-3 pt-3 border-t border-border">
    {links.site && (
      <a 
        href={links.site} 
        target="_blank" 
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-sm text-muted hover:text-accent transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
        {lang === 'ru' ? 'Сайт' : 'Site'}
      </a>
    )}
    {links.github && (
      <a 
        href={links.github} 
        target="_blank" 
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-sm text-muted hover:text-accent transition-colors"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        GitHub
      </a>
    )}
    {links.demo && (
      <a 
        href={links.demo} 
        target="_blank" 
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-sm text-muted hover:text-accent transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Demo
      </a>
    )}
  </div>
</div>

<style>
  .bg-success\/20 {
    background-color: color-mix(in srgb, var(--success) 20%, transparent);
  }
  .border-success\/30 {
    border-color: color-mix(in srgb, var(--success) 30%, transparent);
  }
  .bg-warn\/20 {
    background-color: color-mix(in srgb, var(--warn) 20%, transparent);
  }
  .border-warn\/30 {
    border-color: color-mix(in srgb, var(--warn) 30%, transparent);
  }
  .bg-muted\/20 {
    background-color: color-mix(in srgb, var(--muted) 20%, transparent);
  }
  .border-muted\/30 {
    border-color: color-mix(in srgb, var(--muted) 30%, transparent);
  }
</style>
