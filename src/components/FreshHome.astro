---
import type { CollectionEntry } from 'astro:content';
import type { Lang } from '@/i18n';
import { getFeaturedProjects } from '@/data/projects';
import { resumeShortRu, resumeShortEn } from '@/data/resumeShort';

interface Props {
  lang: Lang;
  latestPosts: CollectionEntry<'blog-ru'>[] | CollectionEntry<'blog-en'>[];
}

const { lang, latestPosts } = Astro.props;
const resume = lang === 'ru' ? resumeShortRu : resumeShortEn;
const featuredProjects = getFeaturedProjects(lang);
const resumeHref = lang === 'ru' ? '/old/resume' : '/old/en/resume';

const projectLab = [
  {
    id: 'hands-xedoc',
    title: 'hands.xedoc.ru',
    status: lang === 'ru' ? 'Жесты и камера' : 'Gestures + camera',
    type: 'camera control lab',
    summary: lang === 'ru'
      ? 'Веб-прототип управления жестами рук и лицевыми сигналами через камеру.'
      : 'A browser prototype for camera-based hand gestures and face-signal control.',
    href: 'https://hands.xedoc.ru',
    stack: ['TypeScript', 'Vite', 'MediaPipe'],
    accent: '#8b5cf6',
    span: true,
  },
  {
    id: 'music-xedoc',
    title: 'music.xedoc.ru',
    status: lang === 'ru' ? 'AI music' : 'AI music',
    type: 'prompt-to-music',
    summary: lang === 'ru'
      ? 'Публичный интерфейс генерации музыки поверх StableDAW и локального inference.'
      : 'A public prompt-to-music interface on top of StableDAW and local inference.',
    href: 'https://music.xedoc.ru',
    stack: ['StableDAW', 'Nginx', 'Python'],
    accent: '#ec4899',
  },
  {
    id: 'crimson-wars',
    title: 'Crimson Wars',
    status: lang === 'ru' ? 'Игра' : 'Game',
    type: lang === 'ru' ? 'co-op zombie survival' : 'co-op zombie survival',
    summary: lang === 'ru'
      ? 'Сессионный кооперативный кровавый сурвайвал против зомби.'
      : 'Session-based co-op bloody survival against zombies.',
    href: 'https://crimson.rodion.pro',
    stack: ['Astro', 'React', 'TypeScript'],
    accent: '#ff705c',
  },
  {
    id: 'reader-market',
    title: 'Reader.Market',
    status: lang === 'ru' ? 'Активный продукт' : 'Active product',
    type: lang === 'ru' ? 'AI-платформа для книг' : 'AI book platform',
    summary: lang === 'ru'
      ? 'Платформа для чтения, публикации и рекомендаций вокруг книжного контента.'
      : 'A platform for reading, publishing, and recommendations around books.',
    href: 'https://reader.market',
    stack: ['React', 'Node.js', 'PostgreSQL', 'AI'],
    accent: '#0f9f8a',
  },
];

const experiments = [
  {
    title: lang === 'ru' ? 'AI tooling' : 'AI tooling',
    text: lang === 'ru' ? 'Пайплайны, промпты, ассистенты и ускорение delivery.' : 'Pipelines, prompts, assistants, and delivery acceleration.',
  },
  {
    title: lang === 'ru' ? 'Desktop agents' : 'Desktop agents',
    text: lang === 'ru' ? 'Локальные приложения, трекинг, синхронизация и приватные данные.' : 'Local apps, tracking, sync, and private data.',
  },
  {
    title: lang === 'ru' ? 'Product systems' : 'Product systems',
    text: lang === 'ru' ? 'MVP, backend, frontend, DevOps и доведение до production.' : 'MVP, backend, frontend, DevOps, and production launch.',
  },
];

const copy = {
  ru: {
    eyebrow: 'PROJECT LAB / RODION.PRO',
    headline: 'Проекты, продукты и эксперименты',
    headlineLines: ['Проекты,', 'продукты и', 'эксперименты'],
    lead: 'Главная витрина того, что я запускаю: веб-продукты, игровые идеи, личная аналитика, AI-инструменты и инфраструктура вокруг них.',
    introTitle: 'Родион Калимуллин',
    introText: 'Senior Full-Stack / Tech Lead / DevOps. Собираю проекты от идеи до production и люблю, когда система выглядит простой снаружи, но крепко держится внутри.',
    primaryCta: 'Смотреть проекты',
    secondaryCta: 'Связаться',
    resumeCta: 'Резюме',
    oldVersion: 'Основная версия',
    nav: [
      { href: '#projects', label: 'Проекты' },
      { href: '#experiments', label: 'Эксперименты' },
      { href: '#stack', label: 'Стек' },
      { href: '#contact', label: 'Связь' },
    ],
    metrics: [
      { value: '4', label: 'проекта на витрине' },
      { value: 'MVP -> prod', label: 'путь от идеи до запуска' },
      { value: 'AI + DevOps', label: 'ускорение сборки продуктов' },
    ],
    activeTitle: 'Активные проекты',
    activeLead: 'Не резюме ради резюме, а карта живых продуктов и экспериментов.',
    experimentsTitle: 'Лаборатория',
    experimentsLead: 'Темы, которые постоянно попадают в мои продукты и прототипы.',
    stackTitle: 'Стек вокруг проектов',
    stackLead: 'Инструменты, которыми я чаще всего собираю и запускаю свои системы.',
    timelineTitle: 'Последние записи',
    timelineLead: 'Заметки и обновления вокруг сайта, продуктов и разработки.',
    noPosts: 'Записи блога появятся здесь.',
    contactTitle: 'Есть идея для проекта?',
    contactLead: 'Можно обсудить продукт, прототип, инфраструктуру или AI-автоматизацию.',
    contactTelegram: 'Telegram',
    contactGithub: 'GitHub',
    open: 'Открыть',
  },
  en: {
    eyebrow: 'PROJECT LAB / RODION.PRO',
    headline: 'Projects, products, and experiments',
    headlineLines: ['Projects,', 'products &', 'experiments'],
    lead: 'A front page for what I launch: web products, game ideas, personal analytics, AI tooling, and the infrastructure around them.',
    introTitle: 'Rodion Kalimullin',
    introText: 'Senior Full-Stack / Tech Lead / DevOps. I take projects from idea to production and like systems that feel simple outside while staying solid inside.',
    primaryCta: 'View projects',
    secondaryCta: 'Contact',
    resumeCta: 'Resume',
    oldVersion: 'Main version',
    nav: [
      { href: '#projects', label: 'Projects' },
      { href: '#experiments', label: 'Experiments' },
      { href: '#stack', label: 'Stack' },
      { href: '#contact', label: 'Contact' },
    ],
    metrics: [
      { value: '4', label: 'showcase projects' },
      { value: 'MVP -> prod', label: 'from idea to launch' },
      { value: 'AI + DevOps', label: 'faster product building' },
    ],
    activeTitle: 'Active projects',
    activeLead: 'Not a resume-first page, but a map of living products and experiments.',
    experimentsTitle: 'Lab notes',
    experimentsLead: 'Themes that keep showing up in my products and prototypes.',
    stackTitle: 'Project stack',
    stackLead: 'Tools I use most often to build and ship systems.',
    timelineTitle: 'Latest posts',
    timelineLead: 'Notes and updates around the site, products, and development.',
    noPosts: 'Blog posts will appear here.',
    contactTitle: 'Have a project idea?',
    contactLead: 'Let’s discuss a product, prototype, infrastructure, or AI automation.',
    contactTelegram: 'Telegram',
    contactGithub: 'GitHub',
    open: 'Open',
  },
}[lang];

const formatDate = (date: Date) => date.toLocaleDateString(lang === 'ru' ? 'ru-RU' : 'en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<div class="project-home w-full overflow-x-hidden bg-bg">
  <header class="border-b border-border bg-bg/90 backdrop-blur">
    <div class="mx-auto flex h-16 max-w-6xl items-center justify-between gap-4 px-4">
      <a href="/alt" class="font-mono text-lg font-bold text-accent">rodion.pro</a>
      <nav class="hidden items-center gap-1 sm:flex">
        {copy.nav.map((item) => (
          <a href={item.href} class="rounded-md px-3 py-2 text-sm font-medium text-muted transition hover:bg-surface hover:text-text">
            {item.label}
          </a>
        ))}
        <a href="/" class="rounded-md border border-border bg-surface px-3 py-2 text-sm font-medium text-text transition hover:border-accent hover:text-accent">
          {copy.oldVersion}
        </a>
      </nav>
    </div>
  </header>

  <main>
    <section id="projects" class="relative border-b border-border">
      <div class="mx-auto grid w-full max-w-6xl grid-cols-1 gap-8 px-4 py-10 lg:min-h-[760px] lg:grid-cols-[1.1fr_0.9fr] lg:items-center lg:py-16">
        <div class="min-w-0 w-full max-w-[21rem] sm:max-w-3xl">
          <p class="inline-flex rounded-full border border-border bg-surface px-3 py-1 text-xs font-bold tracking-wide text-accent shadow-sm">
            {copy.eyebrow}
          </p>
          <h1 class="mt-5 max-w-full text-[2.15rem] font-bold leading-[1.08] text-text sm:text-6xl lg:text-7xl">
            {copy.headlineLines.map((line) => (
              <span class="block">{line}</span>
            ))}
          </h1>
          <p class="mt-5 max-w-2xl text-base leading-7 text-muted sm:text-xl sm:leading-8">
            {copy.lead}
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="#active-projects" class="btn btn-primary">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h7M4 12h16M4 18h10" />
              </svg>
              {copy.primaryCta}
            </a>
            <a href="#contact" class="btn btn-secondary">{copy.secondaryCta}</a>
            <a href="/" class="btn btn-ghost">{copy.oldVersion}</a>
          </div>
        </div>

        <aside class="grid min-w-0 w-full max-w-full grid-cols-1 gap-4">
          <div class="w-full max-w-full overflow-hidden rounded-lg border border-border bg-surface p-5 shadow-sm">
            <div class="flex min-w-0 flex-col items-start justify-between gap-3 sm:flex-row sm:gap-4">
              <div class="min-w-0">
                <p class="text-xs font-bold uppercase tracking-wide text-accent">maker profile</p>
                <h2 class="mt-2 text-2xl font-bold text-text">{copy.introTitle}</h2>
              </div>
              <a href={resumeHref} class="shrink-0 rounded-md border border-border px-3 py-2 text-sm font-semibold text-muted transition hover:border-accent hover:text-accent">
                {copy.resumeCta}
              </a>
            </div>
            <p class="mt-4 break-words text-sm leading-6 text-muted">{copy.introText}</p>
          </div>

          <div class="grid w-full max-w-full grid-cols-1 gap-3 sm:grid-cols-3 lg:grid-cols-1">
            {copy.metrics.map((metric) => (
              <div class="w-full max-w-full overflow-hidden rounded-lg border border-border bg-surface px-5 py-4 shadow-sm">
                <div class="text-2xl font-bold text-text">{metric.value}</div>
                <div class="mt-1 text-sm text-muted">{metric.label}</div>
              </div>
            ))}
          </div>
        </aside>

        <div class="min-w-0 w-full max-w-full lg:col-span-2">
          <div class="project-board grid min-w-0 grid-cols-1 gap-4 lg:grid-cols-4">
            {projectLab.map((project, index) => (
              <a
                href={project.href}
                target={project.href.startsWith('http') ? '_blank' : undefined}
                rel={project.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                class:list={[
                  'group min-w-0 w-full max-w-full overflow-hidden rounded-lg border border-border bg-surface p-5 shadow-sm transition hover:-translate-y-1 hover:shadow-glow-sm',
                  project.span && 'lg:col-span-2 lg:row-span-2',
                ]}
                style={`--project-accent: ${project.accent};`}
              >
                <div class="project-preview mb-5 overflow-hidden rounded-lg border border-border bg-bg">
                  <div class="project-preview-bar">
                    <span></span><span></span><span></span>
                  </div>
                  <div class="project-preview-body">
                    <div class="preview-panel preview-panel-main"></div>
                    <div class="preview-stack">
                      <span></span>
                      <span></span>
                      <span></span>
                    </div>
                  </div>
                </div>
                <div class:list={[
                  'flex min-w-0 flex-col justify-between gap-3',
                  project.span && 'sm:flex-row sm:items-start',
                ]}>
                  <div class="min-w-0">
                    <p class="text-xs font-bold uppercase tracking-wide" style="color: var(--project-accent);">{project.type}</p>
                    <h3 class:list={[
                      'mt-1 break-words font-bold text-text group-hover:text-accent',
                      project.title.includes('.xedoc.ru') ? 'text-lg' : 'text-xl',
                    ]}>
                      {project.title}
                    </h3>
                  </div>
                  <span class="self-start whitespace-nowrap rounded-full px-2 py-1 text-xs font-semibold" style="background: color-mix(in srgb, var(--project-accent) 12%, transparent); color: var(--project-accent);">
                    {project.status}
                  </span>
                </div>
                <p class="mt-4 text-sm leading-6 text-muted">{project.summary}</p>
                <div class="mt-5 flex flex-wrap gap-2">
                  {project.stack.map((tech) => (
                    <span class="rounded-md border border-border bg-bg px-2 py-1 text-xs font-semibold text-muted">{tech}</span>
                  ))}
                </div>
                <div class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-accent">
                  {copy.open}
                  <svg class="h-4 w-4 transition group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14m-6-6 6 6-6 6" />
                  </svg>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section id="active-projects" class="bg-surface">
      <div class="mx-auto max-w-6xl px-4 py-16">
        <div class="flex flex-col justify-between gap-4 sm:flex-row sm:items-end">
          <div>
            <h2 class="text-3xl font-bold text-text">{copy.activeTitle}</h2>
            <p class="mt-3 max-w-2xl text-muted">{copy.activeLead}</p>
          </div>
          <a href="/old/projects" class="link font-medium">{copy.primaryCta} -></a>
        </div>
        <div class="mt-8 grid grid-cols-1 gap-5 md:grid-cols-3">
          {featuredProjects.map((project) => (
            <a href={project.links.site || project.links.github || '/old/projects'} class="min-w-0 overflow-hidden rounded-lg border border-border bg-bg p-5 shadow-sm transition hover:-translate-y-1 hover:shadow-glow-sm">
              <div class="flex items-center justify-between gap-3">
                <h3 class="text-lg font-bold text-text">{project.title}</h3>
                <span class="whitespace-nowrap rounded-full bg-accent/10 px-2 py-1 text-xs font-semibold text-accent">{project.status}</span>
              </div>
              <p class="mt-3 text-sm leading-6 text-muted">{project.tagline}</p>
              <div class="mt-4 flex flex-wrap gap-2">
                {project.stack.slice(0, 5).map((tech) => (
                  <span class="tag">{tech}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section id="experiments" class="border-y border-border bg-surface2/70">
      <div class="mx-auto max-w-6xl px-4 py-16">
        <div class="max-w-2xl">
          <h2 class="text-3xl font-bold text-text">{copy.experimentsTitle}</h2>
          <p class="mt-3 text-muted">{copy.experimentsLead}</p>
        </div>
        <div class="mt-8 grid grid-cols-1 gap-4 md:grid-cols-3">
          {experiments.map((item, index) => (
            <article class="rounded-lg border border-border bg-surface p-5 shadow-sm">
              <div class:list={[
                'mb-4 flex h-10 w-10 items-center justify-center rounded-md text-sm font-bold text-white',
                index === 0 && 'bg-accent',
                index === 1 && 'bg-accent2',
                index === 2 && 'bg-warn',
              ]}>
                {index + 1}
              </div>
              <h3 class="text-lg font-bold text-text">{item.title}</h3>
              <p class="mt-2 text-sm leading-6 text-muted">{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="stack" class="mx-auto grid max-w-6xl grid-cols-1 gap-10 px-4 py-16 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <h2 class="text-3xl font-bold text-text">{copy.stackTitle}</h2>
        <p class="mt-3 text-muted">{copy.stackLead}</p>
        <div class="mt-5 flex flex-wrap gap-2">
          {resume.stackChips.map((tech) => (
            <span class="rounded-md border border-border bg-surface px-3 py-2 text-sm font-semibold text-text shadow-sm">{tech}</span>
          ))}
        </div>
      </div>
      <div>
        <h2 class="text-3xl font-bold text-text">{copy.timelineTitle}</h2>
        <p class="mt-3 text-muted">{copy.timelineLead}</p>
        <div class="mt-5 grid grid-cols-1 gap-3">
          {latestPosts.length === 0 ? (
            <p class="rounded-lg border border-border bg-surface p-5 text-sm text-muted">{copy.noPosts}</p>
          ) : (
            latestPosts.map((post) => (
              <a href={`/old/blog/${post.slug}`} class="rounded-lg border border-border bg-surface p-5 shadow-sm transition hover:border-accent hover:shadow-glow-sm">
                <time class="font-mono text-xs text-muted">{formatDate(post.data.date)}</time>
                <h3 class="mt-2 font-bold text-text">{post.data.title}</h3>
                <p class="mt-1 line-clamp-2 text-sm text-muted">{post.data.description}</p>
              </a>
            ))
          )}
        </div>
      </div>
    </section>

    <section id="contact" class="bg-surface">
      <div class="mx-auto flex max-w-6xl flex-col justify-between gap-6 border-t border-border px-4 py-12 sm:flex-row sm:items-center">
        <div>
          <h2 class="text-3xl font-bold text-text">{copy.contactTitle}</h2>
          <p class="mt-2 text-muted">{copy.contactLead}</p>
        </div>
        <div class="flex flex-wrap gap-3">
          <a href="https://t.me/WizardJIOCb" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
            {copy.contactTelegram}
          </a>
          <a href="https://github.com/WizardJIOCb" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
            {copy.contactGithub}
          </a>
        </div>
      </div>
    </section>
  </main>

  <footer class="border-t border-border bg-bg">
    <div class="mx-auto flex max-w-6xl flex-col justify-between gap-4 px-4 py-8 text-sm text-muted sm:flex-row sm:items-center">
      <p>&copy; 2026 Rodion. {lang === 'ru' ? 'Проектная лаборатория.' : 'Project lab.'}</p>
      <a href="/" class="font-medium text-accent hover:underline">{copy.oldVersion}</a>
    </div>
  </footer>
</div>

<style>
  .project-home,
  .project-home *,
  .project-home *::before,
  .project-home *::after {
    box-sizing: border-box;
  }

  .project-home :where(h1, h2, h3, p, a, span) {
    overflow-wrap: break-word;
    word-break: normal;
  }

  .project-home .btn {
    max-width: 100%;
    white-space: normal;
  }

  .project-preview {
    aspect-ratio: 16 / 9;
  }

  .project-preview-bar {
    display: flex;
    gap: 6px;
    padding: 10px;
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--project-accent) 10%, var(--surface));
  }

  .project-preview-bar span {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--project-accent);
    opacity: 0.8;
  }

  .project-preview-body {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 12px;
    padding: 14px;
  }

  .preview-panel {
    min-height: 86px;
    border-radius: 8px;
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--project-accent) 28%, transparent), transparent),
      var(--surface);
    border: 1px solid color-mix(in srgb, var(--project-accent) 25%, var(--border));
  }

  .preview-stack {
    display: grid;
    gap: 8px;
  }

  .preview-stack span {
    min-height: 22px;
    border-radius: 6px;
    background: color-mix(in srgb, var(--project-accent) 18%, var(--surface));
    border: 1px solid color-mix(in srgb, var(--project-accent) 20%, var(--border));
  }

  @media (max-width: 480px) {
    .project-preview {
      aspect-ratio: auto;
    }

    .project-preview-body {
      grid-template-columns: 1fr;
    }

    .preview-panel {
      min-height: 72px;
    }
  }
</style>
