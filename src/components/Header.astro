---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n';
import LanguageSwitch from '@/components/LanguageSwitch.astro';
import ThemeSwitch from '@/components/ThemeSwitch';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;

const navItems = [
  { key: 'nav.projects' as const, path: '/projects' },
  { key: 'nav.blog' as const, path: '/blog' },
  { key: 'nav.changelog' as const, path: '/changelog' },
  { key: 'nav.now' as const, path: '/now' },
  { key: 'nav.activity' as const, path: '/activity' },
  { key: 'nav.uses' as const, path: '/uses' },
];
---

<header class="sticky top-0 z-50 border-b border-border bg-bg/80 backdrop-blur-md">
  <div class="mx-auto w-full max-w-5xl px-4">
    <nav class="site-nav grid h-16 grid-cols-[minmax(0,1fr)_auto] items-center gap-3 md:flex md:justify-between">
      <a 
        href={getLocalizedPath('/', lang)} 
        class="flex min-w-0 items-center gap-2 font-mono text-base font-semibold text-accent hover:glow-text transition-all sm:text-lg"
      >
        <span class="text-muted">~/</span>rodion
      </a>
      
      <div class="desktop-nav hidden items-center gap-1 md:flex">
        {navItems.map(({ key, path }) => {
          const localizedPath = getLocalizedPath(path, lang);
          const isActive = currentPath.startsWith(localizedPath);
          return (
            <a
              href={localizedPath}
              class:list={[
                'px-3 py-2 rounded-md text-sm font-medium transition-colors',
                isActive 
                  ? 'text-accent bg-accent/10' 
                  : 'text-muted hover:text-text hover:bg-surface',
              ]}
            >
              {t(key)}
            </a>
          );
        })}
      </div>
      
      <div class="site-controls hidden min-w-0 shrink-0 items-center justify-end gap-1 sm:flex sm:gap-2">
        <button
          id="cmd-trigger"
          class="hidden sm:flex items-center gap-2 px-3 py-1.5 rounded-md border border-border text-sm text-muted hover:text-text hover:border-accent/50 transition-colors"
          title="Alt+K"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <span class="font-mono text-xs">Alt+K</span>
        </button>
        
        <div class="hidden sm:block">
          <ThemeSwitch client:load />
        </div>
        <LanguageSwitch />
        
        <button
          id="mobile-menu-btn"
          class="rounded-md p-1.5 text-muted hover:bg-surface hover:text-text md:hidden sm:p-2"
          aria-label="Menu"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </nav>
    
    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <div class="flex flex-col gap-1">
        {navItems.map(({ key, path }) => {
          const localizedPath = getLocalizedPath(path, lang);
          const isActive = currentPath.startsWith(localizedPath);
          return (
            <a
              href={localizedPath}
              class:list={[
                'px-3 py-2 rounded-md text-sm font-medium transition-colors',
                isActive 
                  ? 'text-accent bg-accent/10' 
                  : 'text-muted hover:text-text hover:bg-surface',
              ]}
            >
              {t(key)}
            </a>
          );
        })}
      </div>
    </div>
  </div>
</header>

<style>
  @media (max-width: 639px) {
    .site-controls {
      display: none !important;
    }
  }

  @media (max-width: 767px) {
    .desktop-nav {
      display: none !important;
    }
  }
</style>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const cmdTrigger = document.getElementById('cmd-trigger');
  
  menuBtn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
  
  cmdTrigger?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('toggle-command-palette'));
  });
</script>
