# Site
SITE_URL=https://rodion.pro

# Database
DATABASE_URL=postgres://user:password@localhost:5432/rodion_pro

# GitHub Webhook
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# Deploy Events
DEPLOY_TOKEN=your-deploy-token-here

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Admin (comma-separated emails)
ADMIN_EMAILS=admin@example.com

# Optional: Cloudflare Turnstile (anti-spam)
# TURNSTILE_SITEKEY=your-turnstile-sitekey
# TURNSTILE_SECRET=your-turnstile-secret
